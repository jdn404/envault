{
  "name": "@jadendev/envault",
  "version": "1.0.2",
  "description": "The last env validation library you'll ever need. Zero dependencies, full TypeScript inference, multi-env loading, encryption-ready, and a CLI that buries everything else.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./next": {
      "import": "./dist/plugins/next.mjs",
      "require": "./dist/plugins/next.js",
      "types": "./dist/plugins/next.d.ts"
    },
    "./vite": {
      "import": "./dist/plugins/vite.mjs",
      "require": "./dist/plugins/vite.js",
      "types": "./dist/plugins/vite.d.ts"
    },
    "./presets": {
      "import": "./dist/presets.mjs",
      "require": "./dist/presets.js",
      "types": "./dist/presets.d.ts"
    }
  },
  "bin": {
    "envault": "./bin/envault.js"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "env",
    "environment",
    "validation",
    "typescript",
    "dotenv",
    "config",
    "type-safe",
    "zero-dependency",
    "cli",
    "secrets",
    "envalid",
    "t3-env",
    "dotenvx"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdn404/envault.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}

