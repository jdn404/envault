{
  "name": "envault",
  "version": "1.0.0",
  "description": "Runtime environment variable validation with automatic TypeScript types",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./next": "./dist/plugins/next.js",
    "./vite": "./dist/plugins/vite.js"
  },
  "bin": {
    "envault": "./bin/envault.js"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["env", "environment", "validation", "typescript", "dotenv", "config"],
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jdn404/envault.git"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.0.0"
  }
}
